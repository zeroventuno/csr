# Copia questo file in ".env.local" e compila i valori.

# ---- Supabase ----
# Da: Supabase > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key (SEGRETA — solo lato server, mai esporre al client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Area riservata (admin) ----
ADMIN_PASSWORD=roero-admin
EDITOR_PASSWORD=roero-editor

# Segreto per firmare il cookie di sessione (stringa lunga e casuale)
AUTH_SECRET=cambia-questo-segreto-con-una-stringa-lunga-e-casuale

# ---- Modulo contatti (n8n) ----
# URL del webhook n8n che riceve i messaggi del form /contatti (POST JSON).
# Se vuoto, il form mostra un messaggio e invita a scrivere via email.
N8N_CONTACT_WEBHOOK_URL=
